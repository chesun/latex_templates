\mode<presentation>

% Settings
\definecolor{ucdavisBlue}{cmyk}{1,0.56,0,0.34}
\definecolor{ucdavisGold}{RGB}{255,191,0}
\definecolor{progressgray}{RGB}{211,211,211} % Light gray (for uncompleted part)

\setbeamercolor*{title  page header}{fg=white}
\setbeamercolor*{author}{fg=white}
\setbeamercolor*{date}{fg=white}
\setbeamercolor*{institute}{fg=white}
\setbeamercolor*{footnote}{fg=white}


\let\oldemph\emph
\renewcommand{\emph}[1]{\textcolor{ucdavisBlue}{\oldemph{#1}}}

\let\oldtextbf\textbf
\renewcommand{\textbf}[1]{\textcolor{ucdavisGold}{\oldtextbf{#1}}}

\setbeamercolor{section in toc}{fg=ucdavisBlue}
\setbeamercolor{subsection title}{fg=ucdavisBlue}



\setbeamercolor{itemize item}{fg=ucdavisBlue}
\setbeamercolor{itemize subitem}{fg=ucdavisBlue}
\setbeamercolor{itemize subsubitem}{fg=ucdavisBlue}

\setbeamercolor{enumerate item}{fg=ucdavisGold}
\setbeamercolor{enumerate subitem}{fg=ucdavisGold}
\setbeamercolor{enumerate subsubitem}{fg=ucdavisGold}


\setbeamercolor{button}{bg=ucdavisGold!70,fg=white}

\setbeamercolor{block title}{bg=ucdavisBlue, fg=white, use=structure }
\setbeamercolor{block body}{bg=ucdavisBlue!8, fg=black, use=structure }

% Title slide + band colors (refined-brand-bands redesign)
\setbeamercolor{title}{fg=white}
\setbeamercolor{frametitle}{bg=ucdavisBlue, fg=white}
\setbeamercolor{footline}{bg=ucdavisBlue, fg=white}
\setbeamercolor{udaccentbar}{bg=ucdavisGold} % the gold hairline between bands



\mode<all>