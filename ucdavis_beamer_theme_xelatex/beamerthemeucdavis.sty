\mode<presentation>

% Requirement
\RequirePackage{tikz}
\RequirePackage{fontspec}
\RequirePackage{xcolor}          % For color definitions
\RequirePackage{etoolbox}        % For list processing
\RequirePackage{pgfpages}        % (Optional)
\RequirePackage{totcount}
\regtotcounter{section}

% Layout parameters — derived from paper size so they hold at any aspect ratio.
% Tune the whole theme's spacing from here (defined before \useinnertheme so the
% inner/outer themes can use them).
\newlength{\udmargin}\setlength{\udmargin}{0.045\paperwidth}       % side padding inside bands
\newlength{\udaccent}\setlength{\udaccent}{2.5pt}                  % gold accent band thickness
\newlength{\udtitlepad}\setlength{\udtitlepad}{1.35em}             % vertical padding in the header band
\newlength{\udgoldblock}\setlength{\udgoldblock}{0.22\paperheight} % title-slide gold strip height

% Settings
\useinnertheme{ucdavis}
\useoutertheme{ucdavis}
\usecolortheme{ucdavis}
\usefonttheme{professionalfonts}
\setmainfont{Helvetica Neue}
\setsansfont{Helvetica Neue}
\renewcommand{\familydefault}{\sfdefault}

\newsavebox{\circlebox}
\newsavebox{\textbox}

\setbeamerfont{section in toc}{size=\small}

\setbeamerfont{subsection in toc}{size=\footnotesize}

\setbeamerfont{title}{size=\LARGE,series=\bfseries}
\setbeamerfont{frametitle}{size=\LARGE,series=\bfseries}
\setbeamerfont{framenumber}{size=\small}
\setbeamerfont{section title}{size=\huge,series=\bfseries}
\setbeamerfont{section eyebrow}{size=\small}


	\setbeamertemplate{itemize item}{--}
    \setbeamertemplate{itemize subitem}[circle]
    \setbeamertemplate{itemize subsubitem}{--}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{blocks}[rounded][shadow=false] 


% Sleek TOC: a gold numbered circle + the section title, with generous spacing
% and no rules (the full-width rules read as dated). Subsections are indented and
% muted for hierarchy.
\setbeamertemplate{section in toc}{%
  \leavevmode
  \tikz[baseline=-0.5ex]{%
    \node[shape=circle, fill=ucdavisGold, inner sep=1pt, minimum size=1.25em]
      {\textcolor{white}{\inserttocsectionnumber}};}%
  \hspace{0.6em}{\usebeamerfont{section in toc}\textcolor{ucdavisBlue}{\inserttocsection}}%
  \par\vskip1.2ex
}

\setbeamertemplate{subsection in toc}{%
  \leavevmode
  \hspace{2.4em}{\usebeamerfont{subsection in toc}\textcolor{ucdavisBlue!55}{\textbullet\hspace{0.5em}\inserttocsubsection}}%
  \par\vskip0.5ex
}

% --------------------------------------------------
% Count the total number of sections
%  (for the progress bar)
% --------------------------------------------------
\newcounter{totalsections}
% Patch \section so that each time it is used, we increment totalsections.
\pretocmd{\section}{\stepcounter{totalsections}}{}{}


% --------------------------------------------------
% Define a TikZ-based progress bar for "section x of y"
% --------------------------------------------------
% This progress bar is 3cm wide and 0.3cm tall.
% It fills with ucdavisGold for the completed portion and shows the rest in progressgray.
\newcommand{\sectionprogressbar}{%
  \begin{tikzpicture}[baseline]
    \def\barwidth{8} % width in cm
    \def\barheight{0.1} % height in cm
    % Avoid division by zero: if totalsections > 0, compute fraction, else set to 0.
    \ifnum\value{totalsections}>0
      \pgfmathsetmacro{\progress}{\insertframenumber/\inserttotalframenumber}
    \else
      \def\progress{0}
    \fi
    % Draw the full bar (light gray background)
    \fill[fill=progressgray] (0,0) rectangle (\barwidth, \barheight);
    % Draw the completed portion (gold), width = total width * progress
    \fill[fill=ucdavisGold] (0,0) rectangle ({\barwidth * \progress}, \barheight);
  \end{tikzpicture}%
}

% --------------------------------------------------
% Automatic Section Title Frame
% --------------------------------------------------
% \AtBeginSection runs each time we enter a new \section{...}
% We'll display the section title plus the progress bar on its own slide.
% --------------------------------------------------
% Automatic Section Title Slide with Progress Bar
% --------------------------------------------------
\AtBeginSection[]
{%
  {%
    % Full-bleed Aggie-blue "chapter break": a gold "SECTION N" eyebrow above the
    % large white section title. Minimal — no rule, no progress bar.
    \setbeamertemplate{background}{%
      \begin{tikzpicture}
        \useasboundingbox (0,0) rectangle (\the\paperwidth,\the\paperheight);
        \fill[ucdavisBlue] (0,0) rectangle (\the\paperwidth,\the\paperheight);
      \end{tikzpicture}%
    }
    \begin{frame}[plain]
      \vfill
      \hspace*{\udmargin}%
      \begin{minipage}{\dimexpr\paperwidth-2\udmargin\relax}
        \raggedright
        {\usebeamerfont{section eyebrow}\color{ucdavisGold}SECTION~\insertsectionnumber\par}
        \vskip0.5em
        {\usebeamerfont{section title}\color{white}\insertsection\par}
      \end{minipage}
      \vfill
    \end{frame}%
  }%
}




\mode<all>