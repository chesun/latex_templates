% beamerthemecaedlab.sty — single-file build, AUTO-GENERATED by scripts/bundle.sh.
% Source of truth: ca_ed_lab_beamer_theme/ in https://github.com/chesun/latex_templates
% Do NOT edit here; edit the four split .sty files and re-run scripts/bundle.sh.
\mode<presentation>

% California Education Lab beamer theme — ported from the official CEL PowerPoint
% template (Calibri/navy/gold). Uses pdfLaTeX + Carlito (the free, metric-compatible
% Calibri clone), so it needs no system fonts or XeLaTeX. All spacing derives from
% the paper size, so the theme works at the native 4:3 AND at 16:9 (set via the
% beamer aspectratio option) without edits.

% Requirements
\RequirePackage{tikz}
\RequirePackage[T1]{fontenc}
\RequirePackage{carlito}   % Calibri-metric-compatible font (Carlito)
\RequirePackage{xcolor}
\RequirePackage{titlecaps} % \Titlecap for proper-cased section-divider titles

% --- Brand colors (from the official CEL template) --------------------------
\definecolor{celNavy}{HTML}{014B84}
\definecolor{celGold}{HTML}{DFB305}

% --- Layout parameters (paper-size-derived -> aspect-ratio independent) ------
% Defined before \useinnertheme so the inner/outer themes can use them.
\newlength{\celmargin}\setlength{\celmargin}{0.05\paperwidth}      % side padding in bands
\newlength{\celtitlepad}\setlength{\celtitlepad}{1.0em}            % vertical padding in the header band
\newlength{\celaccent}\setlength{\celaccent}{2pt}                  % gold accent rule under the header band
\newlength{\celtitlerule}\setlength{\celtitlerule}{4pt}            % thicker gold divider on the title slide
\newlength{\celstrip}\setlength{\celstrip}{0.22\paperheight}       % title-slide white logo strip height
\newlength{\celborderinset}\setlength{\celborderinset}{0.035\paperheight} % section-divider gold border inset

% Settings

% Colors are defined in the master (celNavy, celGold).

% Title-slide text sits on the navy field -> white.
\setbeamercolor{title}{fg=white}
\setbeamercolor{author}{fg=white}
\setbeamercolor{institute}{fg=white}
\setbeamercolor{date}{fg=white}

% Body / structure
\setbeamercolor{normal text}{fg=black,bg=white}
\setbeamercolor{structure}{fg=celNavy}
\setbeamercolor{itemize item}{fg=celNavy}
\setbeamercolor{itemize subitem}{fg=celGold}
\setbeamercolor{itemize subsubitem}{fg=celNavy}
\setbeamercolor{alerted text}{fg=celGold}

% Content-slide header band + the full-width gold accent rule under it
\setbeamercolor{frametitle}{bg=celNavy,fg=white}
\setbeamercolor{celaccentbar}{bg=celGold}

% Blocks
\setbeamercolor{block title}{bg=celNavy,fg=white}
\setbeamercolor{block body}{bg=celNavy!8,fg=black}

\setbeamercolor{button}{bg=celGold,fg=white}


% Acknowledgement note on the title slide. Defaults to the official CEL
% placeholder text; replace it in your document with \renewcommand.
\newcommand{\acknowledgement}{Note: [INCLUDE ACKNOWLEDGEMENT LANGUAGE HERE] The research reported here was supported by\dots}
\setbeamerfont{acknowledgement}{size=\scriptsize,shape=\itshape}

% --- Background -------------------------------------------------------------
% Title slide (page 1): navy fills the top, a gold rule marks the boundary, and
% a white strip across the bottom holds the centered CEL logo. Heights derive
% from \paperheight, so this holds at 4:3 and 16:9. Content slides stay white.
\setbeamertemplate{background}{%
  \ifnum\thepage=1\relax
    \begin{tikzpicture}
      \useasboundingbox (0,0) rectangle (\the\paperwidth,\the\paperheight);
      \fill[celNavy] (0,\celstrip) rectangle (\the\paperwidth,\the\paperheight);
      \draw[celGold,line width=\celtitlerule] (0,\celstrip) -- (\the\paperwidth,\celstrip);
      \node[anchor=center] at (0.5\paperwidth,0.5\celstrip)
        {\includegraphics[height=0.66\celstrip]{cel_logo.png}};
    \end{tikzpicture}%
  \fi
}

% --- Title page -------------------------------------------------------------
% Centered white title + bold presenter + italic affiliation on the navy field,
% with the (centered) acknowledgement note above the white logo strip, which is
% reserved by the trailing \vskip\celstrip. The logo is drawn by the background.
\defbeamertemplate*{title page}{caedlab}[1][]{%
  \vskip0.14\paperheight
  \begin{centering}
    {\usebeamerfont{title}\color{white}\inserttitle\par}%
    \vskip1.3em%
    {\usebeamerfont{author}\color{white}\insertauthor\par}%
    \vskip0.5em%
    {\usebeamerfont{institute}\color{white}\insertinstitute\par}%
  \end{centering}
  \vfill
  \ifx\acknowledgement\@empty\else%
    \begin{center}%
    \begin{minipage}{\dimexpr\textwidth-2\celmargin\relax}%
      \centering\usebeamerfont{acknowledgement}\color{white}\acknowledgement%
    \end{minipage}%
    \end{center}%
  \fi%
  \vskip0.03\paperheight
  \vskip\celstrip
}


% --- Frame title ------------------------------------------------------------
% Full-width navy header band (matching the CEL "Title and Content" layout) with
% the title in white, the slide number in the top-right corner, and a gold accent
% rule along the bottom (the gold connector line in the CEL layout). The band
% sizes to the title (one line normally; grows for multi-line). No absolute
% coordinates -> aspect-ratio independent. No footer, to keep slides clean.
\defbeamertemplate*{frametitle}{caedlab}[1][]{%
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,sep=0pt,leftskip=\celmargin,rightskip=\celmargin]{frametitle}%
    \vskip\celtitlepad%
    \begin{minipage}[t]{\dimexpr\paperwidth-2\celmargin-3em\relax}%
      \usebeamerfont{frametitle}\insertframetitle%
    \end{minipage}%
    \hfill%
    \raisebox{0pt}[0pt][0pt]{\usebeamerfont{framenumber}\insertframenumber}%
    \par\vskip\celtitlepad%
  \end{beamercolorbox}%
  \nointerlineskip%
  % Full-bleed gold accent rule (a beamercolorbox, so it spans edge-to-edge like
  % the navy band; a bare \rule would sit at the text margin instead).
  \begin{beamercolorbox}[wd=\paperwidth,ht=\celaccent,dp=0pt,sep=0pt]{celaccentbar}\end{beamercolorbox}%
}

\setbeamertemplate{headline}{}
\setbeamertemplate{footline}{}


\usefonttheme{professionalfonts}        % don't let beamer substitute fonts
\renewcommand{\familydefault}{\sfdefault} % Carlito (sans) is the default family

% Fonts
\setbeamerfont{title}{size=\LARGE}
\setbeamerfont{author}{size=\large,series=\bfseries}
\setbeamerfont{institute}{size=\normalsize,shape=\itshape}
\setbeamerfont{frametitle}{size=\huge}
\setbeamerfont{framenumber}{size=\small}
\setbeamerfont{section title}{size=\huge}
\setbeamerfont{section in toc}{size=\large}
\setbeamerfont{subsection in toc}{size=\normalsize}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{blocks}[rounded][shadow=false]
\setbeamertemplate{itemize item}{\textbullet}
\setbeamertemplate{itemize subitem}{--}
\setbeamertemplate{itemize subsubitem}{\textperiodcentered}

% --- Table of contents: gold numbered circles + navy titles, no rules --------
\setbeamertemplate{section in toc}{%
  \leavevmode
  \tikz[baseline=-0.5ex]{\node[circle,fill=celGold,inner sep=1pt,minimum size=1.45em]%
    {\textcolor{white}{\footnotesize\inserttocsectionnumber}};}%
  \hspace{0.6em}{\usebeamerfont{section in toc}\textcolor{celNavy}{\inserttocsection}}%
  \par\vskip1.2ex
}
\setbeamertemplate{subsection in toc}{%
  \leavevmode\hspace{2.6em}%
  {\usebeamerfont{subsection in toc}\textcolor{celNavy!55}{\textbullet\hspace{0.5em}\inserttocsubsection}}%
  \par\vskip0.5ex
}

% --- Capture the raw section title for proper-casing on the divider ----------
% \insertsection expands to a \hyperlink wrapper (not plain text), which
% titlecaps can't process. Intercept \section to stash the literal title so the
% divider can run it through \titlecap. Handles \section, \section[short]{...},
% and \section*{...}; the rare \section<overlay> form is not preserved.
\let\celorig@section\section
\RenewDocumentCommand{\section}{s o m}{%
  \def\celcursection{#3}%
  \IfBooleanTF{#1}%
    {\celorig@section*{#3}}%
    {\IfNoValueTF{#2}{\celorig@section{#3}}{\celorig@section[#2]{#3}}}%
}

% --- Section divider (ported from the CEL "Section Header" slide) ------------
% Full navy slide with the section title centered in white. Four gold rules sit
% inset from the edges but each spans the full slide width/height, so they cross
% at the corners and run all the way to the borders (matches the official deck).
\AtBeginSection[]{%
  {%
    \setbeamertemplate{background}{%
      \begin{tikzpicture}
        \useasboundingbox (0,0) rectangle (\the\paperwidth,\the\paperheight);
        \fill[celNavy] (0,0) rectangle (\the\paperwidth,\the\paperheight);
        \draw[celGold,line width=1.2pt] (0,\celborderinset) -- (\the\paperwidth,\celborderinset);
        \draw[celGold,line width=1.2pt] (0,\dimexpr\paperheight-\celborderinset\relax) -- (\the\paperwidth,\dimexpr\paperheight-\celborderinset\relax);
        \draw[celGold,line width=1.2pt] (\celborderinset,0) -- (\celborderinset,\the\paperheight);
        \draw[celGold,line width=1.2pt] (\dimexpr\paperwidth-\celborderinset\relax,0) -- (\dimexpr\paperwidth-\celborderinset\relax,\the\paperheight);
      \end{tikzpicture}%
    }
    \begin{frame}[plain]
      \vfill
      \begin{centering}
        {\usebeamerfont{section title}\color{white}%
          \titlecap{\celcursection}\par}%
      \end{centering}
      \vfill
    \end{frame}%
  }%
}

\mode<all>
