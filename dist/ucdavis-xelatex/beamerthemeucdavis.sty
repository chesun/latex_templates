% --- Background -------------------------------------------------------------
% Only the title slide (page 1) gets the brand fields; content slides are white
% and get their band from the frametitle template (outer theme). The gold strip
% height derives from \paperheight, so it holds at any aspect ratio. The date and
% conference are drawn here, pinned centered inside the gold strip (blue on gold)
% — the frame body doesn't reliably reach into the strip, so positioning them in
% the background is what keeps them correctly placed.
\setbeamertemplate{background}{%
  \ifnum\thepage=1\relax
    \begin{tikzpicture}
      \useasboundingbox (0,0) rectangle (\the\paperwidth,\the\paperheight);
      \fill[ucdavisBlue] (0,0) rectangle (\the\paperwidth,\the\paperheight);
      \fill[ucdavisGold] (0,0) rectangle (\the\paperwidth,\udgoldblock);
      \node[anchor=center, align=center, text=ucdavisBlue] at (0.5\paperwidth,0.5\udgoldblock){%
        {\usebeamerfont{date}\insertdate}%
        \ifx\conference\@empty\else\\[7pt]{\usebeamerfont{conference}\conference}\fi%
      };
    \end{tikzpicture}%
  \fi
}

% --- Title page -------------------------------------------------------------
% The blue field holds the title, a short gold rule, the author, and the
% institute, centered via \vfill with generous spacing. The trailing
% \vskip\udgoldblock reserves the gold strip so this block centers in the blue
% field above it. Date + conference are drawn in the strip by the background.
\defbeamertemplate*{title page}{ucdavis}[1][]{%
  \vfill
  \begin{centering}
    {\usebeamerfont{title}\color{white}\inserttitle\par}%
    \vskip0.7em%
    {\color{ucdavisGold}\rule{0.16\paperwidth}{2pt}\par}%
    \vskip1.2em%
    {\usebeamerfont{author}\color{white}\insertauthor\par}%
    \vskip0.6em%
    {\usebeamerfont{institute}\color{white}\insertinstitute\par}%
  \end{centering}
  \vfill
  \vskip\udgoldblock
}


% A full-width gold accent band (drawn as a beamercolorbox so it stacks in
% vertical mode; a bare \rule there would force horizontal mode and break
% \nointerlineskip).
\newcommand{\udgoldhairline}{%
  \begin{beamercolorbox}[wd=\paperwidth,ht=\udaccent,dp=0pt,sep=0pt]{udaccentbar}\end{beamercolorbox}%
}

% --- Frame title ------------------------------------------------------------
% Full-width Aggie-blue band with a gold accent band below and the frame number
% in the top-right corner (no separate footer, to keep slides uncluttered).
% The band sizes to the title: one line normally, growing for multi-line titles.
% No subtitles. No absolute coordinates -> the layout is aspect-ratio independent.
\defbeamertemplate*{frametitle}{ucdavis}[1][]{%
  \nointerlineskip%
  \begin{beamercolorbox}[wd=\paperwidth,sep=0pt,leftskip=\udmargin,rightskip=\udmargin]{frametitle}%
    \vskip\udtitlepad%
    \begin{minipage}[t]{\dimexpr\paperwidth-2\udmargin-3em\relax}%
      \usebeamerfont{frametitle}\insertframetitle%
    \end{minipage}%
    \hfill%
    \raisebox{0pt}[0pt][0pt]{\usebeamerfont{framenumber}\insertframenumber}%
    \par\vskip\udtitlepad%
  \end{beamercolorbox}%
  \nointerlineskip%
  \udgoldhairline%
}

